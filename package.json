{
  "name": "@hughescr/stryker-llm-mutator",
  "version": "0.1.0",
  "description": "LLM-driven mutation generator plugin for Stryker, producing a wider variety of mutants than the built-in formulaic mutators",
  "keywords": [
    "stryker",
    "stryker-plugin",
    "mutation-testing",
    "mutant",
    "llm",
    "ai",
    "anthropic",
    "claude",
    "haiku"
  ],
  "homepage": "https://github.com/hughescr/stryker-llm-mutator#readme",
  "bugs": {
    "url": "https://github.com/hughescr/stryker-llm-mutator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hughescr/stryker-llm-mutator.git"
  },
  "license": "Apache-2.0",
  "author": "hughescr",
  "sideEffects": [
    "./dist/index.js",
    "./dist/cli.js"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "stryker-llm": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build src/index.ts --outdir dist --target node --format esm --packages=external -e '*mutate.js' && bun build src/cli.ts --outdir dist --target node --format esm --packages=external -e '*mutate.js' --banner='#!/usr/bin/env node' && tsc -p tsconfig.dts.json",
    "lint": "oxlint",
    "format": "oxfmt \"**/*.{ts,mts,cts,mjs,cjs,js}\"",
    "format:check": "oxfmt --check \"**/*.{ts,mts,cts,mjs,cjs,js}\"",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:injection": "bun test tests/injection/",
    "canary": "bun test tests/injection/canary.test.ts",
    "mutate": "stryker run",
    "clones": "jscpd src/",
    "dead-code": "knip",
    "prepublishOnly": "bun run build",
    "postversion": "git commit -m \"Bump package version to $npm_package_version\" package.json; git flow release start $npm_package_version; git flow release finish -m $npm_package_version $npm_package_version; git checkout develop; git merge main"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.186",
    "@babel/parser": "^7.29.0",
    "@babel/types": "^7.29.0",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@stryker-mutator/api": ">=9.6.0 <10",
    "@stryker-mutator/core": ">=9.6.0 <10",
    "@stryker-mutator/instrumenter": ">=9.6.0 <10"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@hughescr/stryker-bun-runner": "1.2.2",
    "@stryker-mutator/api": "9.6.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/instrumenter": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@types/bun": "1.3.14",
    "@types/node": "26.0.0",
    "jscpd": "5.0.11",
    "knip": "6.18.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
